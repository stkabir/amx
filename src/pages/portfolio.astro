---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects.js';
---

<Layout title="Portfolio" description="Explora el portafolio de AMX Developers — desarrollos residenciales y proyectos de asset management premium en México.">

  <!-- PAGE HERO -->
  <div class="page-hero">
    <div class="page-hero-inner">
      <span class="reveal-mask"><span class="section-label reveal-line" data-i18n="pf-hero-label">Nuestro Trabajo</span></span>
      <h1>
        <span class="reveal-mask"><span class="reveal-line">Portfolio</span></span>
      </h1>
    </div>
  </div>

  <!-- FILTER + GRID -->
  <section class="pf-section">
    <div class="container">

      <div class="pf-controls">
        <div class="pfc-tabs reveal-fade" role="tablist" aria-label="Categorías de proyectos">
          <button class="pfc-tab active" data-filter="all" role="tab" aria-selected="true" data-i18n="pf-tab-all">Todos</button>
          <button class="pfc-tab" data-filter="development" role="tab" aria-selected="false" data-i18n="pf-tab-dev">Desarrollo</button>
          <button class="pfc-tab" data-filter="asset" role="tab" aria-selected="false" data-i18n="pf-tab-asset">Asset Management</button>
        </div>
      </div>

      <!-- Featured row (first two, large) -->
      <div class="pf-featured" id="pf-featured">
        {projects.slice(0, 2).map((proj, i) => (
          <a href={`/proyectos/${proj.slug}`} class="pff-card" data-category={proj.category}>
            <div class="pffc-visual">
              <img
                src={proj.image}
                alt={proj.name}
                class="pffc-img"
                loading={i === 0 ? 'eager' : 'lazy'}
              />
              <div class="pffc-overlay"></div>
              <span class="pffc-status">{proj.status}</span>
              <div class="pffc-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </div>
            </div>
            <div class="pffc-info">
              <div class="pffc-meta">
                <span>{proj.type}</span>
                <span>{proj.detail}</span>
              </div>
              <h2 class="pffc-name">{proj.name}</h2>
              <p class="pffc-loc">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="11" height="11"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {proj.location}
              </p>
              <p class="pffc-desc">{proj.desc}</p>
              <span class="pffc-cta" data-i18n="pf-view">Ver proyecto →</span>
            </div>
          </a>
        ))}
      </div>

      <!-- Regular grid (rest) -->
      <div class="pf-grid reveal-stagger" id="pf-grid">
        {projects.slice(2).map(proj => (
          <a href={`/proyectos/${proj.slug}`} class="pfg-card" data-category={proj.category}>
            <div class="pfgc-visual">
              <img src={proj.image} alt={proj.name} class="pfgc-img" loading="lazy" />
              <div class="pfgc-overlay"></div>
              <span class="pfgc-status">{proj.status}</span>
              <div class="pfgc-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </div>
            </div>
            <div class="pfgc-info">
              <p class="pfgc-type">{proj.type}</p>
              <h3 class="pfgc-name">{proj.name}</h3>
              <p class="pfgc-loc">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="11" height="11"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {proj.location}
              </p>
              <p class="pfgc-desc">{proj.desc}</p>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- CONTACT CTA -->
  <section class="pf-cta">
    <div class="container">
      <div class="pfc-inner">
        <div class="pfci-left">
          <span class="reveal-mask"><span class="section-label reveal-line" data-i18n="pf-cta-label">¿Interesado?</span></span>
          <h2 class="pfci-h2">
            <span class="reveal-mask"><span class="reveal-line" data-i18n="pf-cta-h2-1">Hablemos</span></span>
            <span class="reveal-mask"><span class="reveal-line" data-i18n="pf-cta-h2-2">de tu proyecto</span></span>
          </h2>
        </div>
        <div class="pfci-right reveal-fade">
          <a href="/contact" class="btn btn-white" data-i18n="pf-cta-btn">Contactanos</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* SECTION */
  .pf-section {
    padding: clamp(4rem, 8vw, 7rem) 0;
    border-bottom: 1px solid var(--border);
  }

  /* CONTROLS */
  .pf-controls {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 2.5rem;
  }
  .pfc-tabs { display: flex; gap: 0.25rem; flex-wrap: wrap; }
  .pfc-tab {
    font-family: 'Epilogue', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.6rem 1.25rem;
    border: 1px solid var(--border);
    color: var(--gray);
    background: transparent;
    cursor: pointer;
    border-radius: 1px;
    transition: all 0.2s;
  }
  .pfc-tab:hover { color: #0D111B; border-color: rgba(0,0,0,0.3); }
  .pfc-tab.active { background: var(--dark); color: #fff; border-color: var(--dark); }

  /* ── FEATURED ─────────────────────────────────── */
  .pf-featured {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5px;
    margin-bottom: 1.5px;
  }
  .pff-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .pff-card.hidden { display: none; }

  .pffc-visual {
    position: relative;
    aspect-ratio: 3/2;
    overflow: hidden;
  }
  .pffc-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .pff-card:hover .pffc-img { transform: scale(1.05); }

  .pffc-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(13,17,27,0.75) 0%, rgba(13,17,27,0.15) 55%);
    transition: opacity 0.4s;
  }
  .pff-card:hover .pffc-overlay { opacity: 0.7; }

  .pffc-status {
    position: absolute; top: 1.25rem; left: 1.25rem;
    font-size: 0.6rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(255,255,255,0.9);
    border: 1px solid rgba(255,255,255,0.3);
    padding: 0.3rem 0.75rem; backdrop-filter: blur(4px);
    background: rgba(13,17,27,0.2);
  }

  .pffc-arrow {
    position: absolute; bottom: 1.25rem; right: 1.25rem;
    width: 44px; height: 44px;
    border: 1px solid rgba(255,255,255,0.5);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff; z-index: 5;
    transform: scale(0);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .pff-card:hover .pffc-arrow { transform: scale(1); }

  .pffc-info {
    padding: 1.5rem 1.75rem 2rem;
    background: #F5F2EE;
    border-bottom: 1px solid var(--border);
  }
  .pffc-meta {
    display: flex; justify-content: space-between;
    font-size: 0.65rem; font-weight: 600; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--gray);
    margin-bottom: 0.5rem;
  }
  .pffc-name { font-size: 1.6rem; font-weight: 700; letter-spacing: -0.02em; color: #0D111B; margin-bottom: 0.4rem; transition: opacity 0.2s; }
  .pff-card:hover .pffc-name { opacity: 0.7; }
  .pffc-loc {
    display: flex; align-items: center; gap: 0.3rem;
    font-size: 0.78rem; color: var(--gray); margin-bottom: 0.9rem;
  }
  .pffc-desc { font-size: 0.88rem; line-height: 1.7; color: var(--gray); font-weight: 300; max-width: 500px; margin-bottom: 1rem; }
  .pffc-cta {
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--gray); transition: color 0.2s;
  }
  .pff-card:hover .pffc-cta { color: #0D111B; }

  /* ── REGULAR GRID ─────────────────────────────── */
  .pf-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
  }
  .pfg-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .pfg-card.hidden { display: none; }

  .pfgc-visual {
    position: relative; aspect-ratio: 4/3; overflow: hidden;
  }
  .pfgc-img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .pfg-card:hover .pfgc-img { transform: scale(1.06); }

  .pfgc-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(13,17,27,0.78) 0%, rgba(13,17,27,0.1) 55%);
    transition: opacity 0.4s;
  }
  .pfg-card:hover .pfgc-overlay { opacity: 0.6; }

  .pfgc-status {
    position: absolute; top: 1rem; left: 1rem;
    font-size: 0.58rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(255,255,255,0.85); border: 1px solid rgba(255,255,255,0.25);
    padding: 0.25rem 0.65rem; backdrop-filter: blur(4px);
    background: rgba(13,17,27,0.2);
  }
  .pfgc-arrow {
    position: absolute; bottom: 1rem; right: 1rem;
    width: 38px; height: 38px;
    border: 1px solid rgba(255,255,255,0.5);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff; z-index: 5;
    transform: scale(0);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .pfg-card:hover .pfgc-arrow { transform: scale(1); }

  .pfgc-info {
    padding: 1.25rem 1.5rem 1.75rem;
    background: #F5F2EE;
    border-bottom: 1px solid var(--border);
  }
  .pfgc-type { font-size: 0.62rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gray); margin-bottom: 0.35rem; }
  .pfgc-name { font-size: 1.2rem; font-weight: 700; letter-spacing: -0.01em; color: #0D111B; margin-bottom: 0.35rem; transition: opacity 0.2s; }
  .pfg-card:hover .pfgc-name { opacity: 0.7; }
  .pfgc-loc { display: flex; align-items: center; gap: 0.3rem; font-size: 0.75rem; color: var(--gray); margin-bottom: 0.7rem; }
  .pfgc-desc { font-size: 0.83rem; line-height: 1.7; color: var(--gray); font-weight: 300; }

  /* CTA */
  .pf-cta {
    padding: clamp(6rem, 12vw, 10rem) 0;
    background: var(--blue);
    color: #fff;
  }
  .pfc-inner { display: grid; grid-template-columns: 1fr auto; gap: 4rem; align-items: center; }
  .pfci-h2 { font-size: clamp(2.5rem, 5vw, 4.5rem); font-weight: 700; letter-spacing: -0.03em; line-height: 1; margin-top: 0.75rem; }
  .pfci-right { display: flex; align-items: center; }

  /* Blue CTA section — buttons stay white on dark bg */
  .pf-cta .btn-white { background: #fff; color: var(--blue); border-color: #fff; }
  .pf-cta .btn-white:hover { background: transparent; color: #fff; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .pf-featured { grid-template-columns: 1fr; }
    .pf-grid { grid-template-columns: 1fr; }
    .pfc-inner { grid-template-columns: 1fr; }
  }
  @media (min-width: 600px) and (max-width: 900px) {
    .pf-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script is:inline>
(function () {
  const tabs  = document.querySelectorAll('.pfc-tab');
  const feat  = document.querySelectorAll('#pf-featured .pff-card');
  const cards = document.querySelectorAll('#pf-grid .pfg-card');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      const f = tab.dataset.filter;

      [...feat, ...cards].forEach(card => {
        if (f === 'all' || card.dataset.category === f) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
})();
</script>
