---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    id: 'torre-belgrano',
    name: 'Torre Belgrano',
    location: 'Belgrano, Buenos Aires',
    type: 'High-Rise Residential',
    category: 'development',
    status: 'Completed',
    detail: '34 Floors · 280 Units',
    desc: 'A landmark residential tower redefining the Belgrano skyline. Premium apartments with panoramic city views, designed for modern urban living at its finest.',
    bg: 'linear-gradient(160deg, #060d18 0%, #0a1e38 60%, #0d2850 100%)',
    accent: '#0d2850',
  },
  {
    id: 'palermo-uno',
    name: 'Palermo Uno',
    location: 'Palermo, Buenos Aires',
    type: 'Mixed-Use Development',
    category: 'development',
    status: 'In Development',
    detail: '22 Floors · Retail + Residential',
    desc: 'A mixed-use development at the heart of Palermo, blending ground-floor retail with premium residential levels and a rooftop amenity deck.',
    bg: 'linear-gradient(160deg, #07101c 0%, #0c1c30 60%, #112440 100%)',
    accent: '#112440',
  },
  {
    id: 'puerto-madero-iii',
    name: 'Puerto Madero III',
    location: 'Puerto Madero, Buenos Aires',
    type: 'Luxury Waterfront',
    category: 'development',
    status: 'Completed',
    detail: '48 Floors · 160 Units',
    desc: 'Our most iconic waterfront development. Ultra-luxury residences in Buenos Aires\' most prestigious address, with unobstructed Río de la Plata views.',
    bg: 'linear-gradient(160deg, #050c16 0%, #081824 60%, #0b2236 100%)',
    accent: '#0b2236',
  },
  {
    id: 'nordelta-reserve',
    name: 'Nordelta Reserve',
    location: 'Tigre, Buenos Aires',
    type: 'Gated Community',
    category: 'asset',
    status: 'In Development',
    detail: '280 Homes · 45 ha',
    desc: 'An exclusive gated community set within 45 hectares of curated landscape in Tigre, where design, nature and privacy converge.',
    bg: 'linear-gradient(160deg, #080f1a 0%, #0d1a28 60%, #102030 100%)',
    accent: '#102030',
  },
  {
    id: 'palermo-soho-lofts',
    name: 'Palermo Soho Lofts',
    location: 'Palermo Soho, Buenos Aires',
    type: 'Boutique Residences',
    category: 'asset',
    status: 'Completed',
    detail: '8 Floors · 64 Lofts',
    desc: 'Intimate loft-style residences in the creative heart of Palermo Soho, with exposed concrete, double-height ceilings and artisan finishes.',
    bg: 'linear-gradient(160deg, #0a0c14 0%, #10182a 60%, #1a2840 100%)',
    accent: '#1a2840',
  },
  {
    id: 'recoleta-premier',
    name: 'Recoleta Premier',
    location: 'Recoleta, Buenos Aires',
    type: 'Heritage Conversion',
    category: 'asset',
    status: 'Ongoing',
    detail: '12 Floors · Heritage Building',
    desc: 'A meticulous restoration of a heritage Recoleta building, converting upper floors into premium managed residences while preserving its Belle Époque facade.',
    bg: 'linear-gradient(160deg, #0a0810 0%, #181020 60%, #201835 100%)',
    accent: '#201835',
  },
];
---

<Layout title="Portfolio" description="Explore AMX Developers' portfolio of premium residential and mixed-use developments across Buenos Aires.">

  <!-- PAGE HERO -->
  <div class="page-hero">
    <div class="page-hero-inner">
      <span class="reveal-mask"><span class="section-label reveal-line">Our Work</span></span>
      <h1>
        <span class="reveal-mask"><span class="reveal-line">Portfolio</span></span>
      </h1>
    </div>
  </div>

  <!-- FILTER + GRID -->
  <section class="pf-section">
    <div class="container">

      <div class="pf-controls">
        <div class="pfc-tabs reveal-fade" role="tablist" aria-label="Project categories">
          <button class="pfc-tab active" data-filter="all" role="tab" aria-selected="true">All Projects</button>
          <button class="pfc-tab" data-filter="development" role="tab" aria-selected="false">Development</button>
          <button class="pfc-tab" data-filter="asset" role="tab" aria-selected="false">Asset Management</button>
        </div>
      </div>

      <!-- Featured row (first two, large) -->
      <div class="pf-featured" id="pf-featured">
        {projects.slice(0, 2).map(proj => (
          <article class="pff-card" data-category={proj.category} id={proj.id}>
            <div class="pffc-visual" style={`background: ${proj.bg}`}>
              <div class="pffc-grid-lines" aria-hidden="true"></div>
              <div class="pffc-building" aria-hidden="true">
                <div class="pfb-col pfb-tall" style={`background: ${proj.accent}80`}></div>
                <div class="pfb-col pfb-mid" style={`background: ${proj.accent}99`}></div>
                <div class="pfb-col pfb-short" style={`background: ${proj.accent}70`}></div>
                <div class="pfb-col pfb-tall2" style={`background: ${proj.accent}88`}></div>
                <div class="pfb-col pfb-xs" style={`background: ${proj.accent}60`}></div>
              </div>
              <div class="pffc-overlay"></div>
              <div class="pffc-plus" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                  <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </div>
              <span class="pffc-status">{proj.status}</span>
            </div>
            <div class="pffc-info">
              <div class="pffc-meta">
                <span>{proj.type}</span>
                <span>{proj.detail}</span>
              </div>
              <h2 class="pffc-name">{proj.name}</h2>
              <p class="pffc-loc">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="11" height="11"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {proj.location}
              </p>
              <p class="pffc-desc">{proj.desc}</p>
            </div>
          </article>
        ))}
      </div>

      <!-- Regular grid (rest) -->
      <div class="pf-grid reveal-stagger" id="pf-grid">
        {projects.slice(2).map(proj => (
          <article class="pfg-card" data-category={proj.category} id={proj.id}>
            <div class="pfgc-visual" style={`background: ${proj.bg}`}>
              <div class="pfgc-grid-lines" aria-hidden="true"></div>
              <div class="pfgc-building" aria-hidden="true">
                <div class="pfb-col pfb-tall" style={`background: ${proj.accent}80`}></div>
                <div class="pfb-col pfb-mid" style={`background: ${proj.accent}99`}></div>
                <div class="pfb-col pfb-short" style={`background: ${proj.accent}70`}></div>
                <div class="pfb-col pfb-tall2" style={`background: ${proj.accent}88`}></div>
              </div>
              <div class="pfgc-overlay"></div>
              <div class="pfgc-plus" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
                  <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </div>
              <span class="pfgc-status">{proj.status}</span>
            </div>
            <div class="pfgc-info">
              <p class="pfgc-type">{proj.type}</p>
              <h3 class="pfgc-name">{proj.name}</h3>
              <p class="pfgc-loc">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="11" height="11"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {proj.location}
              </p>
              <p class="pfgc-desc">{proj.desc}</p>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>

  <!-- CONTACT CTA -->
  <section class="pf-cta">
    <div class="container">
      <div class="pfc-inner">
        <div class="pfci-left">
          <span class="reveal-mask"><span class="section-label reveal-line">Interested?</span></span>
          <h2 class="pfci-h2">
            <span class="reveal-mask"><span class="reveal-line">Let's talk</span></span>
            <span class="reveal-mask"><span class="reveal-line">about your project</span></span>
          </h2>
        </div>
        <div class="pfci-right reveal-fade">
          <a href="/contact" class="btn btn-white">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* SECTION */
  .pf-section {
    padding: clamp(4rem, 8vw, 7rem) 0;
    border-bottom: 1px solid var(--border);
  }

  /* CONTROLS */
  .pf-controls {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 2.5rem;
  }
  .pfc-tabs { display: flex; gap: 0.25rem; flex-wrap: wrap; }
  .pfc-tab {
    font-family: 'Epilogue', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.6rem 1.25rem;
    border: 1px solid var(--border);
    color: var(--gray);
    background: transparent;
    cursor: pointer;
    border-radius: 1px;
    transition: all 0.2s;
  }
  .pfc-tab:hover { color: #fff; border-color: rgba(255,255,255,0.3); }
  .pfc-tab.active { background: #fff; color: var(--dark); border-color: #fff; }

  /* ── FEATURED ─────────────────────────────────── */
  .pf-featured {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5px;
    margin-bottom: 1.5px;
  }
  .pff-card { cursor: default; }
  .pff-card.hidden { display: none; }

  .pffc-visual {
    position: relative;
    aspect-ratio: 3/2;
    overflow: hidden;
  }
  .pffc-grid-lines {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(90deg, rgba(255,255,255,0.03) 0, transparent 1px, transparent 32px),
      repeating-linear-gradient(0deg, rgba(255,255,255,0.03) 0, transparent 1px, transparent 32px);
  }
  .pffc-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(13,17,27,0.85) 0%, transparent 55%);
    transition: opacity 0.4s;
  }
  .pff-card:hover .pffc-overlay { opacity: 0.5; }
  .pffc-building {
    position: absolute;
    bottom: 0; left: 50%;
    transform: translateX(-50%);
    width: 65%; height: 72%;
    display: flex; align-items: flex-end; gap: 3px;
    transition: transform 0.5s ease;
  }
  .pff-card:hover .pffc-building { transform: translateX(-50%) scale(1.03); }
  .pfb-col { border-radius: 1px 1px 0 0; flex: 1; }
  .pfb-tall { height: 95%; } .pfb-mid { height: 68%; } .pfb-short { height: 48%; } .pfb-tall2 { height: 82%; } .pfb-xs { height: 36%; }

  .pffc-plus {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%) scale(0);
    width: 56px; height: 56px;
    border: 1px solid rgba(255,255,255,0.6);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff; z-index: 5;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .pff-card:hover .pffc-plus { transform: translate(-50%, -50%) scale(1); }

  .pffc-status {
    position: absolute; top: 1.25rem; left: 1.25rem;
    font-size: 0.6rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(255,255,255,0.9);
    border: 1px solid rgba(255,255,255,0.3);
    padding: 0.3rem 0.75rem; backdrop-filter: blur(4px);
  }

  .pffc-info {
    padding: 1.5rem 1.75rem 2rem;
    background: var(--dark);
    border-bottom: 1px solid var(--border);
  }
  .pffc-meta {
    display: flex; justify-content: space-between;
    font-size: 0.65rem; font-weight: 600; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--gray);
    margin-bottom: 0.5rem;
  }
  .pffc-name { font-size: 1.6rem; font-weight: 700; letter-spacing: -0.02em; color: #fff; margin-bottom: 0.4rem; }
  .pffc-loc {
    display: flex; align-items: center; gap: 0.3rem;
    font-size: 0.78rem; color: var(--gray); margin-bottom: 0.9rem;
  }
  .pffc-desc { font-size: 0.88rem; line-height: 1.7; color: var(--gray); font-weight: 300; max-width: 500px; }

  /* ── REGULAR GRID ─────────────────────────────── */
  .pf-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
  }
  .pfg-card.hidden { display: none; }

  .pfgc-visual {
    position: relative; aspect-ratio: 4/3; overflow: hidden;
  }
  .pfgc-grid-lines {
    position: absolute; inset: 0;
    background-image:
      repeating-linear-gradient(90deg, rgba(255,255,255,0.025) 0, transparent 1px, transparent 28px),
      repeating-linear-gradient(0deg, rgba(255,255,255,0.025) 0, transparent 1px, transparent 28px);
  }
  .pfgc-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(13,17,27,0.85) 0%, transparent 55%);
    transition: opacity 0.4s;
  }
  .pfg-card:hover .pfgc-overlay { opacity: 0.5; }
  .pfgc-building {
    position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
    width: 60%; height: 70%; display: flex; align-items: flex-end; gap: 3px;
    transition: transform 0.5s;
  }
  .pfg-card:hover .pfgc-building { transform: translateX(-50%) scale(1.04); }
  .pfgc-plus {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%) scale(0);
    width: 46px; height: 46px;
    border: 1px solid rgba(255,255,255,0.5);
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    color: #fff; z-index: 5;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .pfg-card:hover .pfgc-plus { transform: translate(-50%, -50%) scale(1); }
  .pfgc-status {
    position: absolute; top: 1rem; left: 1rem;
    font-size: 0.58rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(255,255,255,0.8); border: 1px solid rgba(255,255,255,0.25);
    padding: 0.25rem 0.65rem; backdrop-filter: blur(4px);
  }
  .pfgc-info {
    padding: 1.25rem 1.5rem 1.75rem;
    background: var(--dark);
    border-bottom: 1px solid var(--border);
  }
  .pfgc-type { font-size: 0.62rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gray); margin-bottom: 0.35rem; }
  .pfgc-name { font-size: 1.2rem; font-weight: 700; letter-spacing: -0.01em; color: #fff; margin-bottom: 0.35rem; transition: opacity 0.2s; }
  .pfg-card:hover .pfgc-name { opacity: 0.7; }
  .pfgc-loc { display: flex; align-items: center; gap: 0.3rem; font-size: 0.75rem; color: var(--gray); margin-bottom: 0.7rem; }
  .pfgc-desc { font-size: 0.83rem; line-height: 1.7; color: var(--gray); font-weight: 300; }

  /* CTA */
  .pf-cta {
    padding: clamp(6rem, 12vw, 10rem) 0;
    background: var(--blue);
  }
  .pfc-inner { display: grid; grid-template-columns: 1fr auto; gap: 4rem; align-items: center; }
  .pfci-h2 { font-size: clamp(2.5rem, 5vw, 4.5rem); font-weight: 700; letter-spacing: -0.03em; line-height: 1; margin-top: 0.75rem; }
  .pfci-right { display: flex; align-items: center; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .pf-featured { grid-template-columns: 1fr; }
    .pf-grid { grid-template-columns: 1fr; }
    .pfc-inner { grid-template-columns: 1fr; }
  }
  @media (min-width: 600px) and (max-width: 900px) {
    .pf-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script is:inline>
(function () {
  const tabs  = document.querySelectorAll('.pfc-tab');
  const feat  = document.querySelectorAll('#pf-featured .pff-card');
  const cards = document.querySelectorAll('#pf-grid .pfg-card');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      const f = tab.dataset.filter;

      [...feat, ...cards].forEach(card => {
        if (f === 'all' || card.dataset.category === f) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
})();
</script>
