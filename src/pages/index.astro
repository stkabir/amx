---
import Layout from '../layouts/Layout.astro';
import { projects as allProjects } from '../data/projects.js';

const projects = allProjects.slice(0, 8);
// const projects = allProjects;
---

<Layout title="Home" description="AMX Developers — Desarrollo inmobiliario premium en México.">

  <!-- ══════════════════════════════════════════════════════ HERO -->
  <section class="hero" id="hero">
    <div class="hero-video" aria-hidden="true">
      <video autoplay muted loop playsinline>
        <source src="/img/vid-amx.mp4" type="video/mp4">
      </video>
    </div>

    <div class="hero-content">
      <div class="hero-label-wrap h-mask">
        <span class="section-label h-line" data-i18n="hero-label">Desarrollo Inmobiliario Premium</span>
      </div>
      <h1 class="hero-h1" id="hero-heading">
        <span class="h-mask">
          <span class="h-line" data-i18n="hero-h1-1">Creando</span>
        </span>
        <span class="h-mask">
          <span class="h-line" data-i18n="hero-h1-2">Comunidades</span>
        </span>
        <span class="h-mask">
          <span class="h-line" data-i18n="hero-h1-3">Excepcionales</span>
        </span>
      </h1>
      <div class="hero-copy h-fade" id="hero-copy">
        <p data-i18n="hero-copy">Somos una firma de desarrollo inmobiliario con base en México, impulsada por una visión global y respaldada por la experiencia de nuestros socios en mercados icónicos. Diseñamos y creamos espacios excepcionales que redefinen el concepto de lujo, elevando el estándar de vida a través de proyectos únicos, sofisticados y atemporales.</p>
      </div>
      <div class="hero-cta h-fade">
        <a href="/portfolio" class="btn btn-white" data-i18n="hero-btn-1">Ver Portafolio</a>
        <a href="/contact" class="btn btn-outline" data-i18n="hero-btn-2">Contáctanos</a>
      </div>
    </div>

    <div class="hero-scroll" aria-hidden="true">
      <div class="hs-line"></div>
      <span class="hs-label" data-i18n="hero-scroll">Scroll</span>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ ABOUT -->
  <section class="about-section" id="about">
    <div class="container">
      <div class="as-inner">
        <div class="as-label">
          <span class="reveal-mask"><span class="section-label reveal-line" data-i18n="home-about-label">Sobre AMX</span></span>
        </div>
        <div class="as-body">
          <div class="as-text">
            <p class="as-p reveal-fade" data-i18n="home-about-p1">
              AMX Developers es una firma de desarrollo inmobiliario con base en México, fundada por socios con amplia experiencia en mercados internacionales como Miami y Nueva York. A lo largo de su trayectoria, el equipo ha participado en el desarrollo de cientos de unidades residenciales y comerciales, aplicando estándares globales y un profundo conocimiento del sector.
            </p>
            <p class="as-p reveal-fade" data-i18n="home-about-p2">
              La visión de la firma se centra en el desarrollo de proyectos premium y de lujo, con acabados high-end y una ejecución alineada a los más altos estándares internacionales. Cada proyecto es concebido para ofrecer una experiencia superior, combinando diseño, calidad y valor a largo plazo.
            </p>
            <a href="/about" class="as-link reveal-fade">
              <span data-i18n="home-about-link">Conócenos más</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ PORTFOLIO -->
  <section class="portfolio-section" id="portfolio">
    <div class="container">

      <div class="ps-header">
        <div class="psh-left">
          <span class="reveal-mask"><span class="section-label reveal-line" data-i18n="home-pf-label">Nuestros Proyectos</span></span>
          <h2 class="ps-title">
            <span class="reveal-mask"><span class="reveal-line" data-i18n="home-pf-title-1">Explora nuestro</span></span>
            <span class="reveal-mask"><span class="reveal-line" data-i18n="home-pf-title-2">portafolio</span></span>
          </h2>
        </div>
        <div class="psh-tabs reveal-fade" role="tablist" aria-label="Portfolio categories">
          <button class="ps-tab active" data-filter="all" role="tab" aria-selected="true" data-i18n="home-pf-tab-all">Todos</button>
          <button class="ps-tab" data-filter="development" role="tab" aria-selected="false" data-i18n="home-pf-tab-dev">Desarrollo</button>
        </div>
      </div>

      <div class="ps-grid reveal-stagger" id="ps-grid">
        {projects.map((proj, i) => (
          <article class="ps-card" data-category={proj.category}>
            <a href={`/proyectos/${proj.slug}`} class="psc-link">
              <div class="psc-visual">
                <img
                  src={proj.image}
                  alt={proj.name}
                  class="psc-img"
                  loading={i < 2 ? 'eager' : 'lazy'}
                />
                <div class="psc-overlay"></div>
                <span class="psc-status">{proj.status}</span>
                <div class="psc-arrow" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </div>
              </div>
              <div class="psc-info">
                <p class="psc-type">{proj.type}</p>
                <p class="psc-name">{proj.name}</p>
                <p class="psc-loc">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="11" height="11"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  {proj.location}
                </p>
                <span class="psc-more" data-i18n="home-pf-view">Ver proyecto →</span>
              </div>
            </a>
          </article>
        ))}
      </div>

      <div class="ps-footer reveal-fade">
        <a href="/portfolio" class="btn btn-outline" data-i18n="home-pf-btn">Ver Todos los Proyectos</a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ CONTACT STRIP -->
  <section class="contact-strip" id="contact-strip">
    <div class="container">
      <div class="cs-inner">
        <div class="cs-left">
          <span class="reveal-mask"><span class="section-label reveal-line" data-i18n="home-cs-label">Contáctanos</span></span>
          <h2 class="cs-title">
            <span class="reveal-mask"><span class="reveal-line" data-i18n="home-cs-title-1">Construyamos</span></span>
            <span class="reveal-mask"><span class="reveal-line" data-i18n="home-cs-title-2">juntos</span></span>
          </h2>
        </div>
        <div class="cs-right reveal-fade">
          <div class="cs-items">
            <a href="mailto:adm@amxdevelopers.com" class="cs-item">
              <span class="csi-label" data-i18n="home-cs-email-label">Email</span>
              <span class="csi-val">adm@amxdevelopers.com</span>
            </a>
            <a href="https://wa.me/5491133839797" class="cs-item">
              <span class="csi-label" data-i18n="home-cs-wa-label">WhatsApp</span>
              <span class="csi-val">+54 9 11 3383 9797</span>
            </a>
            <a href="https://www.instagram.com/amxdevelopers" target="_blank" rel="noopener" class="cs-item">
              <span class="csi-label" data-i18n="home-cs-ig-label">Instagram</span>
              <span class="csi-val">@amxdevelopers</span>
            </a>
          </div>
          <a href="/contact" class="btn btn-white" style="margin-top:2rem;" data-i18n="home-cs-btn">Contáctanos</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ═══ HERO ══════════════════════════════════════════════════════════════ */
  .hero {
    position: relative;
    height: 100dvh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: #F5F2EE;
  }
  .hero-video {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
  }
  .hero-content {
    position: relative;
    z-index: 10;
    padding: var(--pad);
    max-width: var(--max);
    width: 100%;
    margin: 0 auto;
    padding-top: var(--nav-h);
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .hero-h1 {
    font-size: clamp(2.5rem, min(9vw, 15vh), 9rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 0.92;
    margin-bottom: 2rem;
    margin-top: 1rem;
  }
  /* Hero-only reveal helpers (avoids conflict with global .reveal-line handler) */
  .h-mask { overflow: hidden; display: block; }
  .hero-label-wrap { margin-bottom: 0.5rem; }
  .hero-copy {
    max-width: 520px;
    margin-bottom: 2.5rem;
  }
  .hero-copy p {
    font-size: clamp(0.9rem, 1.4vw, 1.05rem);
    line-height: 1.8;
    font-weight: 300;
  }
  .hero-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* Scroll cue */
  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    right: var(--pad);
    display: flex;
    align-items: center;
    gap: 1rem;
    z-index: 10;
  }
  .hs-label {
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gray);
    writing-mode: vertical-rl;
  }
  .hs-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, rgba(13,17,27,0.4), transparent);
    animation: lineFlow 2.2s ease infinite;
  }
  @keyframes lineFlow {
    0%   { transform: scaleY(0); transform-origin: top; opacity: 1; }
    50%  { transform: scaleY(1); transform-origin: top; }
    51%  { transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; opacity: 0.3; }
  }

  /* ═══ ABOUT ════════════════════════════════════════════════════════════ */
  .about-section {
    padding: clamp(6rem, 12vw, 11rem) 0;
    border-bottom: 1px solid var(--border);
  }
  .as-inner {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 5rem;
    align-items: start;
  }
  .as-text { max-width: 680px; }
  .as-p {
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    line-height: 1.85;
    color: var(--gray);
    font-weight: 300;
    margin-bottom: 1.5rem;
  }
  .as-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray);
    margin-top: 0.5rem;
    transition: color 0.2s, gap 0.2s;
  }
  .as-link:hover { color: #0D111B; gap: 0.75rem; }

  /* ═══ PORTFOLIO ════════════════════════════════════════════════════════ */
  .portfolio-section {
    padding: clamp(6rem, 12vw, 11rem) 0;
    border-bottom: 1px solid var(--border);
  }
  .ps-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 4rem;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .ps-title {
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-top: 0.75rem;
  }
  .psh-tabs {
    display: flex;
    gap: 0.25rem;
    align-self: flex-end;
    flex-wrap: wrap;
  }
  .ps-tab {
    font-family: 'Epilogue', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.6rem 1.25rem;
    border: 1px solid var(--border);
    color: var(--gray);
    background: transparent;
    cursor: pointer;
    border-radius: 1px;
    transition: all 0.22s ease;
  }
  .ps-tab:hover { color: #0D111B; border-color: rgba(0,0,0,0.3); }
  .ps-tab.active {
    background: var(--dark);
    color: #fff;
    border-color: var(--dark);
  }

  /* Grid */
  .ps-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5px;
    margin-bottom: 3rem;
  }
  .ps-card { overflow: hidden; }
  .ps-card.hidden { display: none; }
  .psc-link {
    display: block;
    text-decoration: none;
    position: relative;
  }

  /* Visual */
  .psc-visual {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  .psc-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .psc-link:hover .psc-img { transform: scale(1.06); }
  .psc-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(13,17,27,0.78) 0%, rgba(13,17,27,0.1) 55%);
    transition: opacity 0.4s ease;
  }
  .psc-link:hover .psc-overlay { opacity: 0.55; }
  .psc-status {
    position: absolute; top: 1rem; left: 1rem;
    font-size: 0.58rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(255,255,255,0.85); border: 1px solid rgba(255,255,255,0.25);
    padding: 0.25rem 0.65rem; backdrop-filter: blur(4px);
    background: rgba(13,17,27,0.2);
  }
  .psc-arrow {
    position: absolute; bottom: 1rem; right: 1rem;
    width: 40px; height: 40px;
    border: 1px solid rgba(255,255,255,0.5);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff; z-index: 5;
    transform: scale(0);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .psc-link:hover .psc-arrow { transform: scale(1); }

  /* Info */
  .psc-info {
    padding: 1.25rem 1.5rem 1.75rem;
    background: #F5F2EE;
  }
  .psc-type {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 0.35rem;
  }
  .psc-name {
    font-size: 1.2rem;
    font-weight: 700;
    color: #0D111B;
    margin-bottom: 0.35rem;
    letter-spacing: -0.01em;
    transition: opacity 0.2s;
  }
  .psc-link:hover .psc-name { opacity: 0.7; }
  .psc-loc {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    color: var(--gray);
    margin-bottom: 0.75rem;
  }
  .psc-more {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray);
    transition: color 0.2s;
  }
  .psc-link:hover .psc-more { color: #0D111B; }

  .ps-footer { text-align: center; }

  /* ═══ CONTACT STRIP ════════════════════════════════════════════════════ */
  .contact-strip {
    padding: clamp(6rem, 12vw, 11rem) 0;
    background: var(--blue);
    color: #fff;
    --border: rgba(255,255,255,0.15);
    --gray: rgba(255,255,255,0.5);
  }
  .cs-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }
  .cs-title {
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-top: 0.75rem;
  }
  .cs-items {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid rgba(255,255,255,0.15);
  }
  .cs-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.1rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.15);
    gap: 1rem;
    transition: opacity 0.2s;
  }
  .cs-item:hover { opacity: 0.7; }
  .csi-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
  }
  .csi-val {
    font-size: 0.9rem;
    font-weight: 300;
    color: #fff;
    letter-spacing: 0.03em;
  }

  /* ═══ CONTACT STRIP: botón blanco sobre fondo azul ═════════════════════ */
  .contact-strip .btn-white { background: #fff; color: var(--blue); border-color: #fff; }
  .contact-strip .btn-white:hover { background: transparent; color: #fff; }

  /* ═══ RESPONSIVE ════════════════════════════════════════════════════════ */
  @media (max-width: 900px) {
    .as-inner { grid-template-columns: 1fr; gap: 2rem; }
    .ps-grid { grid-template-columns: 1fr; }
    .cs-inner { grid-template-columns: 1fr; gap: 3rem; }
    .ps-header { flex-direction: column; align-items: flex-start; }
  }
  @media (min-width: 600px) and (max-width: 900px) {
    .ps-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script is:inline>
(function () {
  // ─── HERO LINE REVEALS (after page intro, delay) ──────────────────────────
  gsap.fromTo('.hero-h1 .h-line',
    { y: '110%' },
    { y: '0%', duration: 1.1, stagger: 0.12, ease: 'power3.out', delay: 1.2 }
  );
  gsap.fromTo('.hero-label-wrap .h-line',
    { y: '110%' },
    { y: '0%', duration: 0.9, ease: 'power3.out', delay: 1.0 }
  );
  gsap.fromTo('.h-fade',
    { y: 24, opacity: 0 },
    { y: 0, opacity: 1, duration: 0.9, ease: 'power2.out', delay: 1.5, stagger: 0.2 }
  );
  gsap.fromTo('.hero-scroll',
    { opacity: 0 },
    { opacity: 1, duration: 0.8, delay: 2.0 }
  );

  // ─── PORTFOLIO FILTER ────────────────────────────────────────────────────
  const tabs = document.querySelectorAll('.ps-tab');
  const cards = document.querySelectorAll('.ps-card');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      const filter = tab.dataset.filter;

      cards.forEach(card => {
        if (filter === 'all' || card.dataset.category === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
})();
</script>
