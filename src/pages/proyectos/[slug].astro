---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects.js';

export function getStaticPaths() {
  return projects.map(p => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const related = projects.filter(p => p.slug !== project.slug).slice(0, 2);
---

<Layout title={project.name} description={project.desc}>

  <!-- HERO -->
  <section class="proj-hero">
    <div class="proj-hero-media">
      <img src={project.image} alt={project.name} class="proj-hero-img" loading="eager" />
      <div class="proj-hero-grad"></div>
    </div>

    <a href="/portfolio" class="proj-back h-fade">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14">
        <path d="M19 12H5M12 5l-7 7 7 7"/>
      </svg>
      Portfolio
    </a>

    <div class="proj-hero-content">
      <div class="proj-hero-inner container">
        <span class="h-mask"><span class="section-label h-line">{project.type}</span></span>
        <h1 class="proj-title">
          {project.name.split(' ').map((word: string) => (
            <span class="h-mask"><span class="h-line proj-word">{word}</span></span>
          ))}
        </h1>
        <div class="proj-hero-meta h-fade">
          <span class="proj-location-tag">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="12" height="12">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            {project.location}
          </span>
          <span class="proj-status-tag">{project.status}</span>
        </div>
      </div>
    </div>

    <div class="proj-scroll-hint h-fade" aria-hidden="true">
      <span class="psh-line"></span>
    </div>
  </section>

  <!-- STATS BAR -->
  <div class="proj-stats reveal-fade">
    <div class="container">
      <div class="proj-stats-inner">
        {project.floors && (
          <div class="pst-item">
            <span class="pst-value">{project.floors}</span>
            <span class="pst-label">Pisos</span>
          </div>
        )}
        {project.units && (
          <div class="pst-item">
            <span class="pst-value">{project.units}</span>
            <span class="pst-label">{project.type === 'Barrio Privado' ? 'Casas' : 'Unidades'}</span>
          </div>
        )}
        <div class="pst-item">
          <span class="pst-value">{project.area}</span>
          <span class="pst-label">Superficie Total</span>
        </div>
        <div class="pst-item">
          <span class="pst-value">{project.year}</span>
          <span class="pst-label">Año</span>
        </div>
        <div class="pst-item">
          <span class="pst-value pst-status">{project.status}</span>
          <span class="pst-label">Estado</span>
        </div>
      </div>
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <section class="proj-content">
    <div class="container">
      <div class="proj-content-grid">

        <!-- Left: description + features -->
        <div class="proj-main">
          <div class="proj-desc reveal-fade">
            {project.longDesc.map((para: string) => <p>{para}</p>)}
          </div>

          <div class="proj-features reveal-fade">
            <h3 class="pf-heading">
              <span class="reveal-mask"><span class="reveal-line">Destacados del Proyecto</span></span>
            </h3>
            <ul class="pf-list reveal-stagger">
              {project.features.map((feat: string) => (
                <li class="pfl-item">
                  <span class="pfl-dash">—</span>
                  <span>{feat}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Right: sidebar -->
        <aside class="proj-sidebar reveal-fade">
          <div class="psb-card">
            <h3 class="psb-heading">Detalles</h3>
            <dl class="psb-list">
              <div class="psb-row"><dt>Ubicación</dt><dd>{project.location}</dd></div>
              <div class="psb-row"><dt>Tipo</dt><dd>{project.type}</dd></div>
              <div class="psb-row">
                <dt>Categoría</dt>
                <dd>{project.category === 'development' ? 'Desarrollo' : 'Asset Management'}</dd>
              </div>
              <div class="psb-row"><dt>Estado</dt><dd>{project.status}</dd></div>
              {project.year && <div class="psb-row"><dt>Año</dt><dd>{project.year}</dd></div>}
              {project.floors && <div class="psb-row"><dt>Pisos</dt><dd>{project.floors}</dd></div>}
              {project.units && <div class="psb-row"><dt>Unidades</dt><dd>{project.units}</dd></div>}
              <div class="psb-row"><dt>Superficie</dt><dd>{project.area}</dd></div>
            </dl>
            <!-- <a href="/contact" class="btn btn-white psb-cta">Consultar ahora</a> -->
          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="proj-gallery">
    <div class="proj-gallery-grid reveal-fade">
      <div class="pgg-main">
        <img src={project.images[0]} alt={`${project.name} — Vista 1`} loading="lazy" />
      </div>
      <div class="pgg-stack">
        <img src={project.images[1]} alt={`${project.name} — Vista 2`} loading="lazy" />
        <img src={project.images[2]} alt={`${project.name} — Vista 3`} loading="lazy" />
      </div>
    </div>
  </section>

  <!-- MORE PROJECTS -->
  <!-- <section class="proj-more">
    <div class="container">
      <div class="proj-more-header reveal-fade">
        <span class="section-label">Más Proyectos</span>
        <a href="/portfolio" class="pm-all-link">Ver todos →</a>
      </div>
      <div class="proj-more-grid reveal-stagger">
        {related.map(rel => (
          <a href={`/proyectos/${rel.slug}`} class="pmg-card">
            <div class="pmgc-visual">
              <img src={rel.image} alt={rel.name} loading="lazy" />
              <div class="pmgc-overlay"></div>
              <span class="pmgc-status">{rel.status}</span>
            </div>
            <div class="pmgc-info">
              <p class="pmgc-type">{rel.type}</p>
              <h3 class="pmgc-name">{rel.name}</h3>
              <p class="pmgc-loc">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="11" height="11">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                {rel.location}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section> -->

  <!-- CTA -->
  <section class="proj-cta">
    <div class="container">
      <div class="proj-cta-inner">
        <div class="proj-cta-left">
          <span class="reveal-mask"><span class="section-label reveal-line">¿Interesado?</span></span>
          <h2 class="proj-cta-h2">
            <span class="reveal-mask"><span class="reveal-line">Hablemos</span></span>
            <span class="reveal-mask"><span class="reveal-line">de tu proyecto</span></span>
          </h2>
        </div>
        <div class="proj-cta-right reveal-fade">
          <a href="/contact" class="btn btn-white">Contactanos</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── HERO ─────────────────────────────────────── */
  .proj-hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    color: #fff;
  }

  .proj-hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .proj-hero-img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    will-change: transform;
  }
  .proj-hero-grad {
    position: absolute; inset: 0;
    background:
      linear-gradient(to bottom, rgba(13,17,27,0.55) 0%, transparent 30%),
      linear-gradient(to top, rgba(13,17,27,0.95) 0%, rgba(13,17,27,0.5) 45%, transparent 75%);
  }

  .proj-back {
    position: absolute;
    top: calc(var(--nav-h) + 1.5rem);
    left: var(--pad);
    z-index: 10;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    transition: color 0.2s;
  }
  .proj-back:hover { color: #fff; }

  .proj-hero-content {
    position: relative;
    z-index: 5;
    padding-bottom: clamp(3rem, 7vh, 5rem);
  }
  .proj-hero-inner { }

  .proj-title {
    display: flex;
    flex-wrap: wrap;
    gap: 0 0.3em;
    font-size: clamp(3.5rem, 9vw, 9rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.95;
    margin: 0.5rem 0 1.5rem;
  }
  .h-mask { overflow: hidden; display: inline-block; }
  .h-line { display: inline-block; }
  .proj-word { display: inline-block; }

  .proj-hero-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .proj-location-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.65);
    letter-spacing: 0.04em;
  }
  .proj-status-tag {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    border: 1px solid rgba(255,255,255,0.3);
    padding: 0.3rem 0.8rem;
    backdrop-filter: blur(4px);
    background: rgba(13,17,27,0.25);
  }

  .proj-scroll-hint {
    position: absolute;
    bottom: 2rem;
    right: var(--pad);
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .psh-line {
    display: block;
    width: 1px;
    height: 56px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.5), transparent);
    animation: scrollLine 2s ease-in-out infinite;
  }
  @keyframes scrollLine {
    0%   { transform: scaleY(0); transform-origin: top; }
    50%  { transform: scaleY(1); transform-origin: top; }
    51%  { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  /* ── STATS BAR ────────────────────────────────── */
  .proj-stats {
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid var(--border);
  }
  .proj-stats-inner {
    display: flex;
    align-items: stretch;
    flex-wrap: wrap;
  }
  .pst-item {
    flex: 1;
    min-width: 120px;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 2rem 2rem;
    border-right: 1px solid var(--border);
  }
  .pst-item:last-child { border-right: none; }
  .pst-value {
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: black;
    line-height: 1;
  }
  .pst-status {
    font-size: 0.9rem;
    letter-spacing: 0;
    font-weight: 600;
  }
  .pst-label {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gray);
  }

  /* ── CONTENT ──────────────────────────────────── */
  .proj-content {
    padding: clamp(5rem, 10vw, 9rem) 0;
    border-bottom: 1px solid var(--border);
  }
  .proj-content-grid {
    display: grid;
    grid-template-columns: 1.7fr 1fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: start;
  }

  .proj-desc {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    margin-bottom: 4rem;
  }
  .proj-desc p {
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: 1.8;
    color: var(--gray);
    font-weight: 300;
  }
  .proj-desc p:first-child {
    font-size: clamp(1.1rem, 1.6vw, 1.3rem);
    color: #0D111B;
    font-weight: 400;
  }

  .pf-heading {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 1.75rem;
  }
  .pf-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .pfl-item {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.92rem;
    color: #0D111B;
    letter-spacing: 0.01em;
  }
  .pfl-item:first-child { border-top: 1px solid var(--border); }
  .pfl-dash { color: var(--gray); flex-shrink: 0; }

  /* Sidebar */
  .proj-sidebar { position: sticky; top: calc(var(--nav-h) + 2rem); }
  .psb-card {
    background: #fff;
    border: 1px solid var(--border);
    padding: 2rem;
  }
  .psb-heading {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }
  .psb-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 2rem;
  }
  .psb-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
  }
  .psb-row:first-child { padding-top: 0; }
  .psb-list dt {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray);
    flex-shrink: 0;
  }
  .psb-list dd {
    font-size: 0.85rem;
    color: #0D111B;
    text-align: right;
  }
  .psb-cta { width: 100%; justify-content: center; }

  /* ── GALLERY ──────────────────────────────────── */
  .proj-gallery {
    padding: clamp(3rem, 6vw, 5rem) 0;
    border-bottom: 1px solid var(--border);
  }
  .proj-gallery-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 3px;
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 var(--pad);
  }
  .pgg-main {
    overflow: hidden;
  }
  .pgg-main img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
    transition: transform 0.8s ease;
  }
  .pgg-main:hover img { transform: scale(1.04); }
  .pgg-stack {
    display: flex;
    flex-direction: column;
    gap: 3px;
    overflow: hidden;
  }
  .pgg-stack img {
    width: 100%;
    flex: 1;
    object-fit: cover;
    display: block;
    transition: transform 0.8s ease;
    aspect-ratio: 3/2;
  }
  .pgg-stack img:hover { transform: scale(1.04); }

  /* ── MORE PROJECTS ────────────────────────────── */
  .proj-more {
    padding: clamp(5rem, 9vw, 8rem) 0;
    border-bottom: 1px solid var(--border);
  }
  .proj-more-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2.5rem;
  }
  .pm-all-link {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray);
    transition: color 0.2s;
  }
  .pm-all-link:hover { color: #0D111B; }

  .proj-more-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5px;
  }
  .pmg-card { display: block; text-decoration: none; color: inherit; }
  .pmgc-visual {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }
  .pmgc-visual img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }
  .pmg-card:hover .pmgc-visual img { transform: scale(1.05); }
  .pmgc-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(13,17,27,0.7) 0%, transparent 50%);
    transition: opacity 0.4s;
  }
  .pmg-card:hover .pmgc-overlay { opacity: 0.6; }
  .pmgc-status {
    position: absolute; top: 1rem; left: 1rem;
    font-size: 0.58rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(255,255,255,0.85); border: 1px solid rgba(255,255,255,0.25);
    padding: 0.25rem 0.65rem; backdrop-filter: blur(4px);
    background: rgba(13,17,27,0.2);
  }
  .pmgc-info {
    padding: 1.25rem 1.5rem 1.75rem;
    background: #F5F2EE;
    border-bottom: 1px solid var(--border);
  }
  .pmgc-type {
    font-size: 0.62rem; font-weight: 600; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--gray); margin-bottom: 0.3rem;
  }
  .pmgc-name {
    font-size: 1.25rem; font-weight: 700; letter-spacing: -0.01em;
    color: #0D111B; margin-bottom: 0.35rem; transition: opacity 0.2s;
  }
  .pmg-card:hover .pmgc-name { opacity: 0.7; }
  .pmgc-loc {
    display: flex; align-items: center; gap: 0.3rem;
    font-size: 0.75rem; color: var(--gray);
  }

  /* ── CTA ──────────────────────────────────────── */
  .proj-cta {
    padding: clamp(6rem, 12vw, 10rem) 0;
    background: var(--blue);
    color: #fff;
  }
  .proj-cta .btn-white { background: #fff; color: var(--blue); border-color: #fff; }
  .proj-cta .btn-white:hover { background: transparent; color: #fff; }
  .proj-cta-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: center;
  }
  .proj-cta-h2 {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-top: 0.75rem;
  }
  .proj-cta-right { display: flex; align-items: center; }

  /* ── RESPONSIVE ───────────────────────────────── */
  @media (max-width: 1024px) {
    .proj-content-grid { grid-template-columns: 1fr; }
    .proj-sidebar { position: static; }
    .psb-card { max-width: 480px; }
  }
  @media (max-width: 768px) {
    .proj-gallery-grid { grid-template-columns: 1fr; }
    .pgg-stack { flex-direction: row; }
    .pgg-stack img { aspect-ratio: 1; }
    .proj-more-grid { grid-template-columns: 1fr; }
    .proj-cta-inner { grid-template-columns: 1fr; }
    .proj-stats-inner { flex-wrap: wrap; }
    .pst-item { min-width: 45%; border-bottom: 1px solid var(--border); }
  }
  @media (max-width: 480px) {
    .proj-title { font-size: clamp(2.8rem, 14vw, 5rem); }
    .pst-item { min-width: 100%; border-right: none; }
    .pgg-stack { flex-direction: column; }
  }
</style>

<script is:inline>
(function () {
  // Hero parallax
  const heroImg = document.querySelector('.proj-hero-img');
  if (heroImg && window.innerWidth > 768) {
    gsap.to(heroImg, {
      scrollTrigger: {
        trigger: '.proj-hero',
        start: 'top top',
        end: 'bottom top',
        scrub: true,
      },
      y: '25%',
      ease: 'none',
    });
  }

  // Hero text reveal (after page intro)
  const heroLines = document.querySelectorAll('.proj-hero .h-line');
  const heroFades = document.querySelectorAll('.proj-hero .h-fade');

  if (heroLines.length) {
    gsap.fromTo(heroLines,
      { y: '110%' },
      {
        y: '0%',
        stagger: 0.09,
        duration: 1.1,
        ease: 'power3.out',
        delay: 1.1,
      }
    );
  }
  if (heroFades.length) {
    gsap.fromTo(heroFades,
      { y: 24, opacity: 0 },
      {
        y: 0, opacity: 1,
        stagger: 0.1,
        duration: 0.85,
        ease: 'power2.out',
        delay: 1.45,
      }
    );
  }
})();
</script>
