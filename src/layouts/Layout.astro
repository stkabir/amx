---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'AMX Developers — Desarrollo Inmobiliario Premium' } = Astro.props;
const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/contact', label: 'Contact' },
];
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.ico" />
  <title>{title} | AMX Developers</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Epilogue:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet" />
</head>

<body>

  <!-- PAGE INTRO (column curtain) -->
  <div id="page-intro" aria-hidden="true">
    <div class="pc"></div>
    <div class="pc"></div>
    <div class="pc"></div>
    <div class="pc"></div>
    <div class="pc"></div>
  </div>

  <!-- HEADER -->
  <header id="site-header">
    <a href="/" class="site-logo" id="site-logo" aria-label="AMX Developers — Home">
      <img src="/img/logo.jpeg" alt="AMX Developers" class="logo-img" />
    </a>

    <button class="menu-btn" id="menu-btn" aria-label="Toggle navigation" aria-expanded="false">
      <div class="menu-icon">
        <span class="ml ml-1"></span>
        <span class="ml ml-2"></span>
        <span class="ml ml-3"></span>
      </div>
    </button>
  </header>

  <!-- FULLSCREEN NAV OVERLAY -->
  <div id="nav-overlay" class="nav-overlay" role="dialog" aria-modal="true" aria-label="Navigation">
    <div class="nav-overlay-inner">

      <!-- Top: small links -->
      <nav class="nav-small-links" aria-label="Primary">
        <ul>
          {navLinks.map((link) => (
            <li class="nsl-item">
              <a
                href={link.href}
                class:list={['nsl-link', { 'is-active': pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href)) }]}
              >
                <span class="nsl-label" data-label={link.label}>{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Bottom: large links with hover image reveal -->
      <nav class="nav-large-links" aria-label="Secondary">
        {navLinks.map((link, i) => (
          <div class="nll-item" style={`--i: ${i}`}>
            <a href={link.href} class="nll-link">
              <span class="nll-text" data-text={link.label}>{link.label}</span>
              <div class="nll-img" style={`background: ${['linear-gradient(135deg,#001020,#003060)','linear-gradient(135deg,#0a1828,#1e3653)','linear-gradient(135deg,#050c18,#002040)','linear-gradient(135deg,#080f1c,#0d1e35)'][i]}`}></div>
            </a>
          </div>
        ))}
      </nav>

    </div>

    <div class="nav-overlay-bottom">
      <div class="nob-contact">
        <a href="mailto:adm@amxdevelopers.com">adm@amxdevelopers.com</a>
        <a href="https://wa.me/5491133839797">+54 9 11 3383 9797</a>
      </div>
      <div class="nob-social">
        <a href="https://www.instagram.com/amxdevelopers" target="_blank" rel="noopener" aria-label="Instagram">IG</a>
        <a href="https://wa.me/5491133839797" target="_blank" rel="noopener" aria-label="WhatsApp">WA</a>
      </div>
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <main id="main">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer id="site-footer">
    <div class="footer-inner">
      <div class="footer-top">
        <div class="ft-col ft-nav">
          <p class="ft-heading" data-i18n="footer-nav-heading">Navegación</p>
          <ul>
            {navLinks.map(link => <li><a href={link.href}>{link.label}</a></li>)}
          </ul>
        </div>

        <div class="ft-col ft-mailing">
          <p class="ft-heading" data-i18n="footer-mailing-heading">Mantente Informado</p>
          <p class="ft-sub" data-i18n="footer-mailing-sub">Suscríbete para recibir nuestras últimas noticias y desarrollos.</p>
          <form class="mailing-form" id="mailing-form">
            <div class="mf-row">
              <input type="email" name="email" placeholder="Tu correo electrónico" required aria-label="Email" autocomplete="email" data-i18n-placeholder="footer-email-ph" />
              <button type="submit" aria-label="Subscribe">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </button>
            </div>
            <p class="mf-success" id="mf-success" aria-live="polite" data-i18n="footer-mailing-success">¡Gracias por suscribirte!</p>
          </form>
        </div>

        <div class="ft-col ft-contact">
          <p class="ft-heading" data-i18n="footer-contact-heading">Contacto</p>
          <address>
            <p data-i18n="footer-location">México</p>
            <a href="mailto:adm@amxdevelopers.com">adm@amxdevelopers.com</a>
            <a href="https://wa.me/5491133839797">+54 9 11 3383 9797</a>
          </address>
        </div>
      </div>

      <div class="footer-bottom">
        <p class="fb-copy">&copy; {new Date().getFullYear()} AMX Developers. <span data-i18n="footer-rights">Todos los derechos reservados.</span></p>
        <div class="fb-social">
          <a href="https://www.instagram.com/amxdevelopers" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href="https://wa.me/5491133839797" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </footer>

