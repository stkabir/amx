    var currentLang = localStorage.getItem('amx-lang') || 'es';

    function applyTranslations(lang) {
      if (!T[lang]) return;
      currentLang = lang;
      window.amxLang = lang;
      document.documentElement.lang = lang;
      var t = T[lang];
      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n');
        if (t[key] !== undefined) el.textContent = t[key];
      });
      document.querySelectorAll('[data-i18n-placeholder]').forEach(function(el) {
        var key = el.getAttribute('data-i18n-placeholder');
        if (t[key] !== undefined) el.placeholder = t[key];
      });
      localStorage.setItem('amx-lang', lang);
    }

    // Expose publicly for programmatic use only: window.amxApplyLang('en')
    window.amxApplyLang = applyTranslations;

    // Apply on initial load (before GSAP animations begin)
    applyTranslations(currentLang);

    // ─── REGISTER GSAP PLUGINS ───────────────────────────────────────────────
    gsap.registerPlugin(ScrollTrigger);

    // ─── PAGE INTRO (column curtain reveal) ──────────────────────────────────
    var introEl = document.getElementById('page-intro');
    if (introEl) {
      gsap.fromTo('.pc',
        { scaleY: 1, transformOrigin: 'top center' },
        {
          scaleY: 0,
          duration: 1.3,
          stagger: { each: 0.07, from: 'start' },
          ease: 'expo.inOut',
          delay: 0.1,
          onComplete: function() { introEl.style.display = 'none'; }
        }
      );
    }

    // ─── HEADER SCROLL ───────────────────────────────────────────────────────
    var siteHeader = document.getElementById('site-header');
    ScrollTrigger.create({
      start: 'top -80',
      onUpdate: function(self) {
        siteHeader.classList.toggle('is-scrolled', self.scroll() > 80);
      }
    });

    // ─── LOGO SCALE ON SCROLL (desktop) ──────────────────────────────────────
    if (window.innerWidth > 991) {
      gsap.to('#site-logo', {
        scrollTrigger: {
          start: 'top top',
          end: '40vh top',
          scrub: 0.6,
        },
        scale: 0.72,
        transformOrigin: 'left center',
        ease: 'none'
      });
    }

    // ─── NAV TOGGLE ──────────────────────────────────────────────────────────
    var menuBtn  = document.getElementById('menu-btn');
    var overlay  = document.getElementById('nav-overlay');
    var nslItems = overlay.querySelectorAll('.nsl-item');
    var nllItems = overlay.querySelectorAll('.nll-item');

    var menuOpen = false;

    var openTl = gsap.timeline({ paused: true });
    openTl
      .set(overlay, { pointerEvents: 'all' })
      .fromTo(overlay,
        { clipPath: 'inset(0 0 100% 0)' },
        { clipPath: 'inset(0 0 0% 0)', duration: 0.9, ease: 'expo.inOut' }
      )
      .fromTo(nslItems,
        { y: 24, opacity: 0 },
        { y: 0, opacity: 1, stagger: 0.06, duration: 0.5, ease: 'power3.out' },
        '-=0.45'
      )
      .fromTo(nllItems,
        { y: 40, opacity: 0 },
        { y: 0, opacity: 1, stagger: 0.08, duration: 0.6, ease: 'power3.out' },
        '-=0.5'
      );

    function openMenu() {
      menuOpen = true;
      menuBtn.setAttribute('aria-expanded', 'true');
      menuBtn.classList.add('is-open');
      document.body.classList.add('menu-open');
      openTl.play();
    }

    function closeMenu() {
      menuOpen = false;
      menuBtn.setAttribute('aria-expanded', 'false');
      menuBtn.classList.remove('is-open');
      document.body.classList.remove('menu-open');
      openTl.reverse();
      setTimeout(function() { overlay.style.pointerEvents = 'none'; }, 900);
    }

    menuBtn.addEventListener('click', function() { menuOpen ? closeMenu() : openMenu(); });

    overlay.querySelectorAll('a').forEach(function(a) {
      a.addEventListener('click', function() { if (menuOpen) closeMenu(); });
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && menuOpen) closeMenu();
    });

    // ─── LARGE NAV LINK: image hover reveal ──────────────────────────────────
    nllItems.forEach(function(item) {
      var img = item.querySelector('.nll-img');
      item.addEventListener('mouseenter', function() {
        gsap.fromTo(img,
          { clipPath: 'inset(100% 0 0 0)' },
          { clipPath: 'inset(0% 0 0 0)', duration: 0.55, ease: 'power3.out' }
        );
      });
      item.addEventListener('mouseleave', function() {
        gsap.to(img, { clipPath: 'inset(0 0 100% 0)', duration: 0.45, ease: 'power3.in' });
      });
    });

    // ─── SMALL NAV LINK: char slide animation ────────────────────────────────
    overlay.querySelectorAll('.nsl-link').forEach(function(link) {
      var label = link.querySelector('.nsl-label');
      var text = label.dataset.label;
      label.innerHTML = text.split('').map(function(c) {
        return '<span class="ch" style="display:inline-block;overflow:hidden;"><span class="chi" style="display:inline-block;">' + (c === ' ' ? '&nbsp;' : c) + '</span></span>';
      }).join('');

      link.addEventListener('mouseenter', function() {
        gsap.to(link.querySelectorAll('.chi'), { y: '-105%', stagger: 0.018, duration: 0.28, ease: 'power2.inOut' });
      });
      link.addEventListener('mouseleave', function() {
        gsap.to(link.querySelectorAll('.chi'), { y: '0%', stagger: { each: 0.018, from: 'end' }, duration: 0.28, ease: 'power2.inOut' });
      });
    });

    // ─── SCROLL REVEAL: lines ────────────────────────────────────────────────
    gsap.utils.toArray('.reveal-line').forEach(function(el) {
      gsap.fromTo(el,
        { y: '105%' },
        {
          y: '0%',
          duration: 1.05,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el.parentElement,
            start: 'top 88%',
          }
        }
      );
    });

    // ─── SCROLL REVEAL: fade-up ───────────────────────────────────────────────
    gsap.utils.toArray('.reveal-fade').forEach(function(el) {
      gsap.fromTo(el,
        { y: 30, opacity: 0 },
        {
          y: 0, opacity: 1, duration: 0.9, ease: 'power2.out',
          scrollTrigger: { trigger: el, start: 'top 88%' }
        }
      );
    });

    // ─── SCROLL REVEAL: staggered group ──────────────────────────────────────
    gsap.utils.toArray('.reveal-stagger').forEach(function(group) {
      gsap.fromTo(Array.from(group.children),
        { y: 40, opacity: 0 },
        {
          y: 0, opacity: 1, stagger: 0.1, duration: 0.8, ease: 'power2.out',
          scrollTrigger: { trigger: group, start: 'top 85%' }
        }
      );
    });

    // ─── MAILING FORM ────────────────────────────────────────────────────────
    var mailingForm = document.getElementById('mailing-form');
    if (mailingForm) {
      mailingForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        await new Promise(function(r) { setTimeout(r, 600); });
        mailingForm.reset();
        var succ = document.getElementById('mf-success');
        if (succ) {
          succ.classList.add('visible');
          setTimeout(function() { succ.classList.remove('visible'); }, 5000);
        }
      });
    }
  })();
  </script>

</body>
</html>

