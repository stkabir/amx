---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'AMX Developers — Desarrollo Inmobiliario Premium' } = Astro.props;
const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', key: 'nav-home', label: 'Inicio' },
  { href: '/about', key: 'nav-about', label: 'Nosotros' },
  { href: '/portfolio', key: 'nav-portfolio', label: 'Portafolio' },
  { href: '/contact', key: 'nav-contact', label: 'Contacto' },
];
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" href="/faviconamx.jpeg" type="image/jpeg" />
  <link rel="apple-touch-icon" href="/faviconamx.jpeg" />
  <title>{title} | AMX Developers</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Epilogue:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet" />
</head>

<body>

  <!-- HEADER -->
  <header id="site-header">
    <a href="/" class="site-logo" id="site-logo" aria-label="AMX Developers — Home">
      <img src="/img/logo.jpeg" alt="AMX Developers" class="logo-img" />
    </a>

    <button class="menu-btn" id="menu-btn" aria-label="Toggle navigation" aria-expanded="false">
      <div class="menu-icon">
        <span class="ml ml-1"></span>
        <span class="ml ml-2"></span>
        <span class="ml ml-3"></span>
      </div>
    </button>
  </header>

  <!-- FULLSCREEN NAV OVERLAY -->
  <div id="nav-overlay" class="nav-overlay" role="dialog" aria-modal="true" aria-label="Navigation">
    <div class="nav-overlay-inner">

      <!-- Top: small links -->
      <nav class="nav-small-links" aria-label="Primary">
        <ul>
          {navLinks.map((link) => (
            <li class="nsl-item">
              <a
                href={link.href}
                class:list={['nsl-link', { 'is-active': pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href)) }]}
              >
                <span class="nsl-label">{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Bottom: large links with hover image reveal -->
      <nav class="nav-large-links" aria-label="Secondary">
        {navLinks.map((link, i) => (
          <div class="nll-item" style={`--i: ${i}`}>
            <a href={link.href} class="nll-link">
              <span class="nll-text">{link.label}</span>
              <div class="nll-img" style={`background: ${['linear-gradient(135deg,#001020,#003060)','linear-gradient(135deg,#0a1828,#1e3653)','linear-gradient(135deg,#050c18,#002040)','linear-gradient(135deg,#080f1c,#0d1e35)'][i]}`}></div>
            </a>
          </div>
        ))}
      </nav>

    </div>

    <div class="nav-overlay-bottom">
      <div class="nob-contact">
        <a href="mailto:adm@amxdevelopers.com">adm@amxdevelopers.com</a>
        <a href="https://wa.me/5491133839797">+54 9 11 3383 9797</a>
      </div>
      <div class="nob-social">
        <a href="https://www.instagram.com/amxdevelopers" target="_blank" rel="noopener" aria-label="Instagram">IG</a>
        <a href="https://wa.me/5491133839797" target="_blank" rel="noopener" aria-label="WhatsApp">WA</a>
      </div>
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <main id="main">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer id="site-footer">
    <div class="footer-inner">
      <div class="footer-top">
        <div class="ft-col ft-nav">
          <p class="ft-heading">Navegación</p>
          <ul>
            {navLinks.map(link => <li><a href={link.href}>{link.label}</a></li>)}
          </ul>
        </div>

        <div class="ft-col ft-mailing">
          <p class="ft-heading">Mantente Informado</p>
          <p class="ft-sub">Suscríbete para recibir nuestras últimas noticias y desarrollos.</p>
          <form class="mailing-form" id="mailing-form">
            <div class="mf-row">
              <input type="email" name="email" placeholder="Tu correo electrónico" required aria-label="Email" autocomplete="email" />
              <button type="submit" aria-label="Subscribe">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </button>
            </div>
            <p class="mf-success" id="mf-success" aria-live="polite">¡Gracias por suscribirte!</p>
          </form>
        </div>

        <div class="ft-col ft-contact">
          <p class="ft-heading">Contacto</p>
          <address>
            <p>México</p>
            <a href="mailto:adm@amxdevelopers.com">adm@amxdevelopers.com</a>
            <a href="https://wa.me/5491133839797">+54 9 11 3383 9797</a>
          </address>
        </div>
      </div>

      <div class="footer-bottom">
        <p class="fb-copy">&copy; {new Date().getFullYear()} AMX Developers. <span>Todos los derechos reservados.</span></p>
        <div class="fb-social">
          <a href="https://www.instagram.com/amxdevelopers" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href="https://wa.me/5491133839797" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </footer>

  <!-- CDN SCRIPTS (load before inline scripts) -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/p5@1.9.4/lib/p5.min.js"></script>

  <script is:inline>
  (function () {
    // ─── HEADER SCROLL ───────────────────────────────────────────────────────
    var siteHeader = document.getElementById('site-header');
    window.addEventListener('scroll', function() {
      siteHeader.classList.toggle('is-scrolled', window.scrollY > 80);
    }, { passive: true });

    // ─── NAV TOGGLE ──────────────────────────────────────────────────────────
    var menuBtn = document.getElementById('menu-btn');
    var overlay = document.getElementById('nav-overlay');
    var menuOpen = false;

    function openMenu() {
      menuOpen = true;
      menuBtn.setAttribute('aria-expanded', 'true');
      menuBtn.classList.add('is-open');
      document.body.classList.add('menu-open');
      overlay.classList.add('is-open');
    }

    function closeMenu() {
      menuOpen = false;
      menuBtn.setAttribute('aria-expanded', 'false');
      menuBtn.classList.remove('is-open');
      document.body.classList.remove('menu-open');
      overlay.classList.remove('is-open');
    }

    menuBtn.addEventListener('click', function() { menuOpen ? closeMenu() : openMenu(); });

    overlay.querySelectorAll('a').forEach(function(a) {
      a.addEventListener('click', function() { if (menuOpen) closeMenu(); });
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && menuOpen) closeMenu();
    });

    // ─── MAILING FORM ────────────────────────────────────────────────────────
    var mailingForm = document.getElementById('mailing-form');
    if (mailingForm) {
      mailingForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        await new Promise(function(r) { setTimeout(r, 600); });
        mailingForm.reset();
        var succ = document.getElementById('mf-success');
        if (succ) {
          succ.classList.add('visible');
          setTimeout(function() { succ.classList.remove('visible'); }, 5000);
        }
      });
    }
  })();
  </script>


  <!-- WhatsApp floating button -->
  <a href="https://wa.me/5491133839797" target="_blank" rel="noopener noreferrer" class="wa-float" aria-label="WhatsApp">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28" aria-hidden="true">
      <path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.978-1.41A9.955 9.955 0 0 0 12 22c5.523 0 10-4.477 10-10S17.523 2 12 2Zm0 18a7.95 7.95 0 0 1-4.054-1.112l-.29-.172-2.953.836.874-2.882-.19-.298A7.95 7.95 0 0 1 4 12c0-4.411 3.589-8 8-8s8 3.589 8 8-3.589 8-8 8Zm4.406-5.846c-.242-.121-1.43-.706-1.652-.786-.222-.08-.384-.121-.545.121-.161.242-.626.786-.767.948-.141.162-.282.182-.524.061-.242-.121-1.022-.377-1.947-1.201-.72-.642-1.206-1.434-1.347-1.676-.141-.242-.015-.373.106-.493.109-.109.242-.283.363-.424.121-.141.161-.242.242-.404.08-.162.04-.303-.02-.424-.061-.121-.545-1.315-.747-1.8-.197-.472-.397-.408-.545-.415l-.464-.008c-.162 0-.424.06-.646.303-.222.242-.848.829-.848 2.022 0 1.193.868 2.346.989 2.507.121.162 1.709 2.608 4.141 3.657.579.25 1.031.399 1.383.511.581.185 1.11.159 1.528.096.466-.07 1.43-.585 1.632-1.15.202-.564.202-1.047.141-1.148-.06-.1-.222-.162-.464-.283Z"/>
    </svg>
  </a>

</body>
</html>

<style is:global>
/* ─── WHATSAPP FLOAT ─────────────────────────────────────────────────────── */
.wa-float {
  position: fixed;
  bottom: 1.75rem;
  right: 1.75rem;
  z-index: 9999;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: #25D366;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(0,0,0,0.22);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.wa-float:hover {
  transform: scale(1.1);
  box-shadow: 0 6px 24px rgba(0,0,0,0.3);
}

/* ─── RESET ─────────────────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html {
  font-family: 'Epilogue', sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  background: #F5F2EE;
  color: #0D111B;
  scroll-behavior: smooth;
}
body { overflow-x: hidden; }
body.menu-open { overflow: hidden; }
img, svg { display: block; max-width: 100%; }
a { color: inherit; text-decoration: none; }
ul, ol { list-style: none; }
button { background: none; border: none; cursor: pointer; font: inherit; color: inherit; }
address { font-style: normal; }
input, textarea { font: inherit; }

/* ─── VARIABLES ─────────────────────────────────────────────────────────── */
:root {
  --dark:  #0D111B;
  --blue:  #1E3653;
  --white: #ffffff;
  --gray:  #666666;
  --border: rgba(0,0,0,0.1);
  --pad: clamp(1.5rem, 5vw, 4rem);
  --max: 1280px;
  --ease-expo: cubic-bezier(0.87, 0, 0.13, 1);
  --nav-h: 70px;
}

/* ─── HEADER ─────────────────────────────────────────────────────────────── */
#site-header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1000;
  height: var(--nav-h);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--pad);
  transition: background 0.4s ease, border-color 0.4s ease;
  border-bottom: 1px solid transparent;
}
#site-header.is-scrolled {
  background: rgba(245, 242, 238, 0.93);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom-color: var(--border);
}

/* LOGO */
.site-logo {
  display: inline-flex;
  align-items: center;
  text-decoration: none;
}
.logo-img {
  height: 52px;
  width: 52px;
  display: block;
  object-fit: cover;
  border-radius: 8px;
}

/* HAMBURGER */
.menu-btn {
  position: relative;
  z-index: 1200;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.menu-icon {
  display: flex;
  flex-direction: column;
  gap: 6px;
  width: 28px;
}
.ml {
  display: block;
  height: 1.5px;
  background: #0D111B;
  transition: transform 0.4s var(--ease-expo), opacity 0.3s ease, width 0.3s ease;
  transform-origin: center;
}
.ml-3 { width: 70%; align-self: flex-end; }

.menu-btn.is-open .ml-1 { transform: translateY(7.5px) rotate(45deg); }
.menu-btn.is-open .ml-2 { opacity: 0; transform: scaleX(0); }
.menu-btn.is-open .ml-3 { transform: translateY(-7.5px) rotate(-45deg); width: 100%; }

/* ─── NAV OVERLAY ────────────────────────────────────────────────────────── */
.nav-overlay {
  position: fixed;
  inset: 0;
  z-index: 900;
  background: #F5F2EE;
  clip-path: inset(0 0 100% 0);
  transition: clip-path 0.6s cubic-bezier(0.87, 0, 0.13, 1);
  pointer-events: none;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: calc(var(--nav-h) + 2rem) var(--pad) 2.5rem;
  overflow: hidden;
}
.nav-overlay.is-open {
  clip-path: inset(0 0 0% 0);
  pointer-events: all;
}
.nav-overlay-inner {
  display: flex;
  flex-direction: column;
  gap: 3rem;
  flex: 1;
}

/* Small links (top) */
.nav-small-links ul {
  display: flex;
  gap: 2.5rem;
  flex-wrap: wrap;
}
.nsl-link {
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gray);
  transition: color 0.2s;
  display: inline-block;
}
.nsl-link.is-active { color: #0D111B; }
.nsl-label { display: inline-block; }

/* Large links (bottom) */
.nav-large-links {
  display: flex;
  flex-direction: column;
  gap: 0;
  border-top: 1px solid var(--border);
  flex: 1;
  justify-content: flex-end;
}
.nll-item {
  border-bottom: 1px solid var(--border);
  position: relative;
  overflow: hidden;
}
.nll-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.1rem 0;
  position: relative;
  z-index: 2;
}
.nll-text {
  font-size: clamp(2.2rem, 6vw, 4.5rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1;
  transition: opacity 0.3s;
  display: block;
  color: #0D111B;
}
.nll-item:hover .nll-text { opacity: 0.6; }
.nll-img {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 200px;
  clip-path: inset(100% 0 0 0);
  transition: clip-path 0.55s cubic-bezier(0.33, 1, 0.68, 1);
  pointer-events: none;
  z-index: 1;
  border-radius: 2px;
}
.nll-item:hover .nll-img { clip-path: inset(0% 0 0 0); }

/* Overlay bottom bar */
.nav-overlay-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 1.5rem;
  border-top: 1px solid var(--border);
  flex-wrap: wrap;
  gap: 1rem;
}
.nob-contact {
  display: flex;
  gap: 2rem;
  flex-wrap: wrap;
}
.nob-contact a {
  font-size: 0.8rem;
  color: var(--gray);
  transition: color 0.2s;
  letter-spacing: 0.04em;
}
.nob-contact a:hover { color: #0D111B; }
.nob-social {
  display: flex;
  gap: 1.5rem;
}
.nob-social a {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  color: var(--gray);
  transition: color 0.2s;
}
.nob-social a:hover { color: #0D111B; }

/* ─── FOOTER ─────────────────────────────────────────────────────────────── */
#site-footer {
  background: #EDE9E3;
  border-top: 1px solid rgba(0,0,0,0.08);
  color: #0D111B;
}
.footer-inner {
  max-width: var(--max);
  margin: 0 auto;
  padding: 0 var(--pad);
}
.footer-top {
  display: grid;
  grid-template-columns: 1fr 2fr 1fr;
  gap: 4rem;
  padding: 5rem 0 4rem;
  border-bottom: 1px solid var(--border);
}
.ft-heading {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gray);
  margin-bottom: 1.5rem;
}
.ft-nav ul {
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}
.ft-nav a {
  font-size: 0.88rem;
  color: var(--gray);
  transition: color 0.2s;
  letter-spacing: 0.02em;
}
.ft-nav a:hover { color: #0D111B; }

.ft-mailing .ft-sub {
  font-size: 0.83rem;
  color: var(--gray);
  line-height: 1.6;
  margin-bottom: 1.5rem;
  max-width: 380px;
}
.mailing-form .mf-row {
  display: flex;
  border-bottom: 1px solid rgba(0,0,0,0.2);
}
.mailing-form input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  color: #0D111B;
  font-size: 0.88rem;
  padding: 0.6rem 0;
  letter-spacing: 0.03em;
}
.mailing-form input::placeholder { color: var(--gray); }
.mailing-form button {
  padding: 0.6rem 0.5rem;
  color: var(--gray);
  transition: color 0.2s;
}
.mailing-form button:hover { color: #0D111B; }
.mf-success {
  display: none;
  font-size: 0.78rem;
  color: var(--gray);
  margin-top: 0.75rem;
  letter-spacing: 0.05em;
}
.mf-success.visible { display: block; }

.ft-contact address {
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
}
.ft-contact address p, .ft-contact address a {
  font-size: 0.85rem;
  color: var(--gray);
  letter-spacing: 0.03em;
  transition: color 0.2s;
}
.ft-contact address a:hover { color: #0D111B; }

.footer-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.75rem 0;
  gap: 1rem;
}
.fb-copy {
  font-size: 0.75rem;
  color: var(--gray);
  letter-spacing: 0.06em;
}
.fb-social {
  display: flex;
  gap: 1.25rem;
}
.fb-social a {
  color: var(--gray);
  transition: color 0.2s;
}
.fb-social a:hover { color: #0D111B; }

/* ─── SHARED UTILITY ─────────────────────────────────────────────────────── */
.container {
  max-width: var(--max);
  margin: 0 auto;
  padding: 0 var(--pad);
}
.section-label {
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--gray);
  display: block;
  margin-bottom: 1.25rem;
}
/* inner page header */
.page-hero {
  padding-top: calc(var(--nav-h) + 5rem);
  padding-bottom: 5rem;
  padding-left: var(--pad);
  padding-right: var(--pad);
  border-bottom: 1px solid var(--border);
}
.page-hero-inner {
  max-width: var(--max);
  margin: 0 auto;
}
.page-hero h1 {
  font-size: clamp(3rem, 8vw, 7rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1;
  margin-top: 1rem;
}

/* ─── BUTTONS ────────────────────────────────────────────────────────────── */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.85rem 2.2rem;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  border-radius: 1px;
  transition: all 0.3s ease;
  cursor: pointer;
  font-family: 'Epilogue', sans-serif;
}
.btn-white {
  background: var(--dark);
  color: #fff;
  border: 1px solid var(--dark);
}
.btn-white:hover {
  background: transparent;
  color: var(--dark);
}
.btn-outline {
  background: transparent;
  color: var(--dark);
  border: 1px solid rgba(0,0,0,0.25);
}
.btn-outline:hover {
  border-color: var(--dark);
}

/* ─── RESPONSIVE ─────────────────────────────────────────────────────────── */
@media (max-width: 768px) {
  .footer-top { grid-template-columns: 1fr; gap: 3rem; padding: 3.5rem 0 3rem; }
  .nav-large-links { gap: 0; }
  .nll-text { font-size: clamp(1.8rem, 9vw, 3rem); }
  .nll-img { width: 120px; }
}
@media (max-width: 480px) {
  :root { --pad: 1.25rem; }
  .nav-small-links ul { gap: 1.25rem; }
}
</style>
