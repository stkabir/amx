---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'AMX Developers — Premium Real Estate Development' } = Astro.props;
const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/contact', label: 'Contact' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.ico" />
  <title>{title} | AMX Developers</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Epilogue:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet" />
</head>

<body>

  <!-- PAGE INTRO (column curtain) -->
  <div id="page-intro" aria-hidden="true">
    <div class="pc"></div>
    <div class="pc"></div>
    <div class="pc"></div>
    <div class="pc"></div>
    <div class="pc"></div>
  </div>

  <!-- HEADER -->
  <header id="site-header">
    <a href="/" class="site-logo" id="site-logo" aria-label="AMX Developers — Home">
      <svg class="logo-hex" viewBox="0 0 52 60" fill="none" width="32" height="37">
        <polygon points="26,2 50,15 50,41 26,54 2,41 2,15" stroke="currentColor" stroke-width="2" fill="none"/>
        <polygon points="26,12 40,20 40,36 26,44 12,36 12,20" stroke="currentColor" stroke-width="1" fill="none" opacity="0.5"/>
      </svg>
      <div class="logo-wordmark">
        <span class="logo-amx">AMX</span>
        <span class="logo-dev">DEVELOPERS</span>
      </div>
    </a>

    <button class="menu-btn" id="menu-btn" aria-label="Toggle navigation" aria-expanded="false">
      <div class="menu-icon">
        <span class="ml ml-1"></span>
        <span class="ml ml-2"></span>
        <span class="ml ml-3"></span>
      </div>
    </button>
  </header>

  <!-- FULLSCREEN NAV OVERLAY -->
  <div id="nav-overlay" class="nav-overlay" role="dialog" aria-modal="true" aria-label="Navigation">
    <div class="nav-overlay-inner">

      <!-- Top: small links -->
      <nav class="nav-small-links" aria-label="Primary">
        <ul>
          {navLinks.map((link) => (
            <li class="nsl-item">
              <a
                href={link.href}
                class:list={['nsl-link', { 'is-active': pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href)) }]}
              >
                <span class="nsl-label" data-label={link.label}>{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Bottom: large links with hover image -->
      <nav class="nav-large-links" aria-label="Secondary">
        {navLinks.map((link, i) => (
          <div class="nll-item" style={`--i: ${i}`}>
            <a href={link.href} class="nll-link">
              <span class="nll-text" data-text={link.label}>{link.label}</span>
              <div class="nll-img" style={`background: ${['linear-gradient(135deg,#001020,#003060)','linear-gradient(135deg,#0a1828,#1e3653)','linear-gradient(135deg,#050c18,#002040)','linear-gradient(135deg,#080f1c,#0d1e35)'][i]}`}></div>
            </a>
          </div>
        ))}
      </nav>

    </div>

    <div class="nav-overlay-bottom">
      <div class="nob-contact">
        <a href="mailto:adm@amxdevelopers.com">adm@amxdevelopers.com</a>
        <a href="https://wa.me/5491133839797">+54 9 11 3383 9797</a>
      </div>
      <div class="nob-social">
        <a href="https://www.instagram.com/amxdevelopers" target="_blank" rel="noopener" aria-label="Instagram">IG</a>
        <a href="https://wa.me/5491133839797" target="_blank" rel="noopener" aria-label="WhatsApp">WA</a>
      </div>
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <main id="main">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer id="site-footer">
    <div class="footer-inner">
      <div class="footer-top">
        <div class="ft-col ft-nav">
          <p class="ft-heading">Navigation</p>
          <ul>
            {navLinks.map(link => <li><a href={link.href}>{link.label}</a></li>)}
          </ul>
        </div>

        <div class="ft-col ft-mailing">
          <p class="ft-heading">Stay Updated</p>
          <p class="ft-sub">Sign up to receive our latest news and developments.</p>
          <form class="mailing-form" id="mailing-form">
            <div class="mf-row">
              <input type="email" name="email" placeholder="Your email address" required aria-label="Email" autocomplete="email" />
              <button type="submit" aria-label="Subscribe">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </button>
            </div>
            <p class="mf-success" id="mf-success" aria-live="polite">Thank you for subscribing!</p>
          </form>
        </div>

        <div class="ft-col ft-contact">
          <p class="ft-heading">Contact</p>
          <address>
            <p>Buenos Aires, Argentina</p>
            <a href="mailto:adm@amxdevelopers.com">adm@amxdevelopers.com</a>
            <a href="https://wa.me/5491133839797">+54 9 11 3383 9797</a>
          </address>
        </div>
      </div>

      <div class="footer-bottom">
        <p class="fb-copy">&copy; {new Date().getFullYear()} AMX Developers. All rights reserved.</p>
        <div class="fb-social">
          <a href="https://www.instagram.com/amxdevelopers" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href="https://wa.me/5491133839797" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </footer>

  <!-- CDN SCRIPTS (load before inline scripts) -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/p5@1.9.4/lib/p5.min.js"></script>

  <script is:inline>
  (function () {
    // ─── REGISTER GSAP PLUGINS ───────────────────────────────────────────────
    gsap.registerPlugin(ScrollTrigger);

    // ─── PAGE INTRO (column curtain reveal) ──────────────────────────────────
    const introEl = document.getElementById('page-intro');
    if (introEl) {
      gsap.fromTo('.pc',
        { scaleY: 1, transformOrigin: 'top center' },
        {
          scaleY: 0,
          duration: 1.3,
          stagger: { each: 0.07, from: 'start' },
          ease: 'expo.inOut',
          delay: 0.1,
          onComplete: () => { introEl.style.display = 'none'; }
        }
      );
    }

    // ─── HEADER SCROLL ───────────────────────────────────────────────────────
    const siteHeader = document.getElementById('site-header');
    ScrollTrigger.create({
      start: 'top -80',
      onUpdate: self => {
        siteHeader.classList.toggle('is-scrolled', self.scroll() > 80);
      }
    });

    // ─── LOGO SCALE ON SCROLL (desktop) ──────────────────────────────────────
    if (window.innerWidth > 991) {
      gsap.to('#site-logo', {
        scrollTrigger: {
          start: 'top top',
          end: '40vh top',
          scrub: 0.6,
        },
        scale: 0.72,
        transformOrigin: 'left center',
        ease: 'none'
      });
    }

    // ─── NAV TOGGLE ──────────────────────────────────────────────────────────
    const menuBtn  = document.getElementById('menu-btn');
    const overlay  = document.getElementById('nav-overlay');
    const nslItems = overlay.querySelectorAll('.nsl-item');
    const nllItems = overlay.querySelectorAll('.nll-item');

    let menuOpen = false;

    const openTl = gsap.timeline({ paused: true });
    openTl
      .set(overlay, { pointerEvents: 'all' })
      .fromTo(overlay,
        { clipPath: 'inset(0 0 100% 0)' },
        { clipPath: 'inset(0 0 0% 0)', duration: 0.9, ease: 'expo.inOut' }
      )
      .fromTo(nslItems,
        { y: 24, opacity: 0 },
        { y: 0, opacity: 1, stagger: 0.06, duration: 0.5, ease: 'power3.out' },
        '-=0.45'
      )
      .fromTo(nllItems,
        { y: 40, opacity: 0 },
        { y: 0, opacity: 1, stagger: 0.08, duration: 0.6, ease: 'power3.out' },
        '-=0.5'
      );

    function openMenu() {
      menuOpen = true;
      menuBtn.setAttribute('aria-expanded', 'true');
      menuBtn.classList.add('is-open');
      document.body.classList.add('menu-open');
      openTl.play();
    }

    function closeMenu() {
      menuOpen = false;
      menuBtn.setAttribute('aria-expanded', 'false');
      menuBtn.classList.remove('is-open');
      document.body.classList.remove('menu-open');
      openTl.reverse();
      setTimeout(() => { overlay.style.pointerEvents = 'none'; }, 900);
    }

    menuBtn.addEventListener('click', () => { menuOpen ? closeMenu() : openMenu(); });

    // Close on nav link click
    overlay.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => { if (menuOpen) closeMenu(); });
    });

    // Close on Escape
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && menuOpen) closeMenu();
    });

    // ─── LARGE NAV LINK: image hover reveal ──────────────────────────────────
    nllItems.forEach(item => {
      const img = item.querySelector('.nll-img');
      item.addEventListener('mouseenter', () => {
        gsap.fromTo(img,
          { clipPath: 'inset(100% 0 0 0)' },
          { clipPath: 'inset(0% 0 0 0)', duration: 0.55, ease: 'power3.out' }
        );
      });
      item.addEventListener('mouseleave', () => {
        gsap.to(img, { clipPath: 'inset(0 0 100% 0)', duration: 0.45, ease: 'power3.in' });
      });
    });

    // ─── SMALL NAV LINK: char slide animation ────────────────────────────────
    overlay.querySelectorAll('.nsl-link').forEach(link => {
      const label = link.querySelector('.nsl-label');
      const text = label.dataset.label;
      label.innerHTML = text.split('').map(c =>
        `<span class="ch" style="display:inline-block;overflow:hidden;"><span class="chi" style="display:inline-block;">${c === ' ' ? '&nbsp;' : c}</span></span>`
      ).join('');

      link.addEventListener('mouseenter', () => {
        gsap.to(link.querySelectorAll('.chi'), { y: '-105%', stagger: 0.018, duration: 0.28, ease: 'power2.inOut' });
      });
      link.addEventListener('mouseleave', () => {
        gsap.to(link.querySelectorAll('.chi'), { y: '0%', stagger: { each: 0.018, from: 'end' }, duration: 0.28, ease: 'power2.inOut' });
      });
    });

    // ─── SCROLL REVEAL: lines ────────────────────────────────────────────────
    // Elements with class .reveal-line must be inside .reveal-mask (overflow:hidden)
    gsap.utils.toArray('.reveal-line').forEach(el => {
      gsap.fromTo(el,
        { y: '105%' },
        {
          y: '0%',
          duration: 1.05,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el.parentElement,
            start: 'top 88%',
          }
        }
      );
    });

    // ─── SCROLL REVEAL: fade-up ───────────────────────────────────────────────
    gsap.utils.toArray('.reveal-fade').forEach(el => {
      gsap.fromTo(el,
        { y: 30, opacity: 0 },
        {
          y: 0, opacity: 1, duration: 0.9, ease: 'power2.out',
          scrollTrigger: { trigger: el, start: 'top 88%' }
        }
      );
    });

    // ─── SCROLL REVEAL: staggered group ──────────────────────────────────────
    gsap.utils.toArray('.reveal-stagger').forEach(group => {
      gsap.fromTo(Array.from(group.children),
        { y: 40, opacity: 0 },
        {
          y: 0, opacity: 1, stagger: 0.1, duration: 0.8, ease: 'power2.out',
          scrollTrigger: { trigger: group, start: 'top 85%' }
        }
      );
    });

    // ─── MAILING FORM ────────────────────────────────────────────────────────
    const mailingForm = document.getElementById('mailing-form');
    if (mailingForm) {
      mailingForm.addEventListener('submit', async e => {
        e.preventDefault();
        await new Promise(r => setTimeout(r, 600));
        mailingForm.reset();
        const succ = document.getElementById('mf-success');
        if (succ) {
          succ.classList.add('visible');
          setTimeout(() => succ.classList.remove('visible'), 5000);
        }
      });
    }
  })();
  </script>

</body>
</html>

<style is:global>
/* ─── RESET ─────────────────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html {
  font-family: 'Epilogue', sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  background: #F5F2EE;
  color: #0D111B;
  scroll-behavior: smooth;
}
body { overflow-x: hidden; }
body.menu-open { overflow: hidden; }
img, svg { display: block; max-width: 100%; }
a { color: inherit; text-decoration: none; }
ul, ol { list-style: none; }
button { background: none; border: none; cursor: pointer; font: inherit; color: inherit; }
address { font-style: normal; }
input, textarea { font: inherit; }

/* ─── VARIABLES ─────────────────────────────────────────────────────────── */
:root {
  --dark:  #0D111B;
  --blue:  #1E3653;
  --white: #ffffff;
  --gray:  #666666;
  --border: rgba(0,0,0,0.1);
  --pad: clamp(1.5rem, 5vw, 4rem);
  --max: 1280px;
  --ease-expo: cubic-bezier(0.87, 0, 0.13, 1);
  --nav-h: 70px;
}

/* ─── PAGE INTRO ─────────────────────────────────────────────────────────── */
#page-intro {
  position: fixed;
  inset: 0;
  z-index: 10000;
  display: flex;
  pointer-events: none;
}
.pc {
  flex: 1;
  background: var(--dark);
  transform-origin: top;
}

/* ─── HEADER ─────────────────────────────────────────────────────────────── */
#site-header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1000;
  height: var(--nav-h);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--pad);
  transition: background 0.4s ease, border-color 0.4s ease;
  border-bottom: 1px solid transparent;
}
#site-header.is-scrolled {
  background: rgba(245, 242, 238, 0.93);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom-color: var(--border);
}

/* LOGO */
.site-logo {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  text-decoration: none;
  transform-origin: left center;
  will-change: transform;
}
.logo-hex { flex-shrink: 0; }
.logo-wordmark {
  display: flex;
  flex-direction: column;
  line-height: 1;
}
.logo-amx {
  font-family: 'Epilogue', sans-serif;
  font-weight: 800;
  font-size: 1.4rem;
  letter-spacing: 0.06em;
  color: #0D111B;
}
.logo-dev {
  font-size: 0.5rem;
  font-weight: 500;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--gray);
}

/* HAMBURGER */
.menu-btn {
  position: relative;
  z-index: 1200;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.menu-icon {
  display: flex;
  flex-direction: column;
  gap: 6px;
  width: 28px;
}
.ml {
  display: block;
  height: 1.5px;
  background: #0D111B;
  transition: transform 0.4s var(--ease-expo), opacity 0.3s ease, width 0.3s ease;
  transform-origin: center;
}
.ml-3 { width: 70%; align-self: flex-end; }

.menu-btn.is-open .ml-1 { transform: translateY(7.5px) rotate(45deg); }
.menu-btn.is-open .ml-2 { opacity: 0; transform: scaleX(0); }
.menu-btn.is-open .ml-3 { transform: translateY(-7.5px) rotate(-45deg); width: 100%; }

/* ─── NAV OVERLAY ────────────────────────────────────────────────────────── */
.nav-overlay {
  position: fixed;
  inset: 0;
  z-index: 900;
  background: #F5F2EE;
  clip-path: inset(0 0 100% 0);
  pointer-events: none;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: calc(var(--nav-h) + 2rem) var(--pad) 2.5rem;
  overflow: hidden;
}
.nav-overlay-inner {
  display: flex;
  flex-direction: column;
  gap: 3rem;
  flex: 1;
}

/* Small links (top) */
.nav-small-links ul {
  display: flex;
  gap: 2.5rem;
  flex-wrap: wrap;
}
.nsl-link {
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gray);
  transition: color 0.2s;
  display: inline-block;
}
.nsl-link.is-active { color: #0D111B; }
.nsl-label { display: inline-block; }

/* Large links (bottom) */
.nav-large-links {
  display: flex;
  flex-direction: column;
  gap: 0;
  border-top: 1px solid var(--border);
  flex: 1;
  justify-content: flex-end;
}
.nll-item {
  border-bottom: 1px solid var(--border);
  position: relative;
  overflow: hidden;
}
.nll-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.1rem 0;
  position: relative;
  z-index: 2;
}
.nll-text {
  font-size: clamp(2.2rem, 6vw, 4.5rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1;
  transition: opacity 0.3s;
  display: block;
  color: #0D111B;
}
.nll-item:hover .nll-text { opacity: 0.6; }
.nll-img {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 200px;
  clip-path: inset(100% 0 0 0);
  pointer-events: none;
  z-index: 1;
  border-radius: 2px;
}

/* Overlay bottom bar */
.nav-overlay-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 1.5rem;
  border-top: 1px solid var(--border);
  flex-wrap: wrap;
  gap: 1rem;
}
.nob-contact {
  display: flex;
  gap: 2rem;
  flex-wrap: wrap;
}
.nob-contact a {
  font-size: 0.8rem;
  color: var(--gray);
  transition: color 0.2s;
  letter-spacing: 0.04em;
}
.nob-contact a:hover { color: #0D111B; }
.nob-social {
  display: flex;
  gap: 1.5rem;
}
.nob-social a {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  color: var(--gray);
  transition: color 0.2s;
}
.nob-social a:hover { color: #0D111B; }

/* ─── FOOTER ─────────────────────────────────────────────────────────────── */
#site-footer {
  background: #EDE9E3;
  border-top: 1px solid rgba(0,0,0,0.08);
  color: #0D111B;
}
.footer-inner {
  max-width: var(--max);
  margin: 0 auto;
  padding: 0 var(--pad);
}
.footer-top {
  display: grid;
  grid-template-columns: 1fr 2fr 1fr;
  gap: 4rem;
  padding: 5rem 0 4rem;
  border-bottom: 1px solid var(--border);
}
.ft-heading {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gray);
  margin-bottom: 1.5rem;
}
.ft-nav ul {
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}
.ft-nav a {
  font-size: 0.88rem;
  color: var(--gray);
  transition: color 0.2s;
  letter-spacing: 0.02em;
}
.ft-nav a:hover { color: #0D111B; }

.ft-mailing .ft-sub {
  font-size: 0.83rem;
  color: var(--gray);
  line-height: 1.6;
  margin-bottom: 1.5rem;
  max-width: 380px;
}
.mailing-form .mf-row {
  display: flex;
  border-bottom: 1px solid rgba(0,0,0,0.2);
}
.mailing-form input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  color: #0D111B;
  font-size: 0.88rem;
  padding: 0.6rem 0;
  letter-spacing: 0.03em;
}
.mailing-form input::placeholder { color: var(--gray); }
.mailing-form button {
  padding: 0.6rem 0.5rem;
  color: var(--gray);
  transition: color 0.2s;
}
.mailing-form button:hover { color: #0D111B; }
.mf-success {
  display: none;
  font-size: 0.78rem;
  color: var(--gray);
  margin-top: 0.75rem;
  letter-spacing: 0.05em;
}
.mf-success.visible { display: block; }

.ft-contact address {
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
}
.ft-contact address p, .ft-contact address a {
  font-size: 0.85rem;
  color: var(--gray);
  letter-spacing: 0.03em;
  transition: color 0.2s;
}
.ft-contact address a:hover { color: #0D111B; }

.footer-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.75rem 0;
  gap: 1rem;
}
.fb-copy {
  font-size: 0.75rem;
  color: var(--gray);
  letter-spacing: 0.06em;
}
.fb-social {
  display: flex;
  gap: 1.25rem;
}
.fb-social a {
  color: var(--gray);
  transition: color 0.2s;
